{
  "name": "financial-dashboard",
  "version": "1.0.0",
  "description": "Modern financial accounting system dashboard with React, Node.js, and PostgreSQL",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "test": "concurrently \"npm run test:server\" \"npm run test:client\"",
    "test:server": "cd server && npm test",
    "test:client": "cd client && npm test",
    "lint": "concurrently \"npm run lint:server\" \"npm run lint:client\"",
    "lint:server": "cd server && eslint .",
    "lint:client": "cd client && eslint src"
  },
  "keywords": ["financial", "dashboard", "accounting", "react", "nodejs"],
  "author": "rokudev-hub2",
  "license": "MIT"
}